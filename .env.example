# Pawprint · Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to git.

# ── GCP Core ──────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── BigQuery ──────────────────────────────────────────────
BQ_DATASET=pawprint_db
BQ_LOCATION=US

# ── Cloud Storage ─────────────────────────────────────────
GCS_BUCKET=your-project-pawprint-raw
GCS_PROCESSED_BUCKET=your-project-pawprint-processed

# ── Pub/Sub ───────────────────────────────────────────────
PUBSUB_INGESTION_TOPIC=ingestion-trigger
PUBSUB_INGESTION_SUB=ingestion-trigger-sub

# ── Vertex AI ─────────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1
VECTOR_SEARCH_INDEX_ID=your-vector-search-index-id
VECTOR_SEARCH_INDEX_ENDPOINT_ID=your-endpoint-id
EMBEDDING_MODEL=text-embedding-004
GENERATION_MODEL=gemini-1.5-flash-002

# ── Document AI ───────────────────────────────────────────
DOCUMENT_AI_PROCESSOR_ID=your-processor-id
DOCUMENT_AI_LOCATION=us

# ── Cloud DLP ─────────────────────────────────────────────
DLP_INSPECT_TEMPLATE=projects/your-project/inspectTemplates/pet-pii-template

# ── Cloud Composer ────────────────────────────────────────
COMPOSER_ENVIRONMENT=pawprint-composer
COMPOSER_LOCATION=us-central1

# ── Serving ───────────────────────────────────────────────
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8080
LOG_LEVEL=INFO
